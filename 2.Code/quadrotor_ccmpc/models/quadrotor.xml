<mujoco model="quadrotor_ccmpc">
  <compiler angle="radian"/>

  <option timestep="0.005" gravity="0 0 -9.81" density="1.2" viscosity="1.8e-5">
    <flag gravity="enable"/>
  </option>

  <size nconmax="100"/>

  <default>
    <motor ctrlrange="0.0 12.0" ctrllimited="true"/>
    <general ctrlrange="0.0 12.0" ctrllimited="true"
             dyntype="none" gaintype="fixed" biastype="none"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.15 0.18 0.22" rgb2="0.20 0.24 0.30"
             width="512" height="512" mark="none"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <visual>
    <headlight ambient="0.5 0.5 0.5" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2"/>
    <map znear="0.01"/>
  </visual>

  <worldbody>
    <light pos="3 3 8" directional="true"/>
    <geom name="floor" type="plane" size="10 10 0.1" material="grid"/>

    <body name="quadrotor" pos="0 0 1" euler="0 0 0">
      <freejoint/>

      <!-- Centre body -->
      <geom name="body" type="box" size="0.08 0.08 0.03" rgba="0.25 0.30 0.85 1"/>
      <geom name="body_inertia" type="ellipsoid" size="0.08 0.08 0.03" mass="1.0" rgba="0 0 0 0"/>

      <!-- Arms (visual only) -->
      <geom name="arm_f" type="cylinder" size="0.008 0.15"
            fromto="0 0 0 0.22 0 0" rgba="0.65 0.65 0.65 0.9"/>
      <geom name="arm_b" type="cylinder" size="0.008 0.15"
            fromto="0 0 0 -0.22 0 0" rgba="0.65 0.65 0.65 0.9"/>
      <geom name="arm_l" type="cylinder" size="0.008 0.15"
            fromto="0 0 0 0 0.22 0" rgba="0.65 0.65 0.65 0.9"/>
      <geom name="arm_r" type="cylinder" size="0.008 0.15"
            fromto="0 0 0 0 -0.22 0" rgba="0.65 0.65 0.65 0.9"/>

      <!-- Rotor sites (force application points) -->
      <site name="rotor1_site" pos="0.22 0.22 0" group="3"/>
      <site name="rotor2_site" pos="-0.22 0.22 0" group="3"/>
      <site name="rotor3_site" pos="-0.22 -0.22 0" group="3"/>
      <site name="rotor4_site" pos="0.22 -0.22 0" group="3"/>

      <!-- Rotor visuals -->
      <body name="rotor1" pos="0.22 0.22 0">
        <geom type="cylinder" size="0.065 0.005" rgba="0.9 0.25 0.25 0.85"/>
      </body>
      <body name="rotor2" pos="-0.22 0.22 0">
        <geom type="cylinder" size="0.065 0.005" rgba="0.25 0.9 0.25 0.85"/>
      </body>
      <body name="rotor3" pos="-0.22 -0.22 0">
        <geom type="cylinder" size="0.065 0.005" rgba="0.25 0.25 0.9 0.85"/>
      </body>
      <body name="rotor4" pos="0.22 -0.22 0">
        <geom type="cylinder" size="0.065 0.005" rgba="0.9 0.9 0.25 0.85"/>
      </body>
    </body>
  </worldbody>

  <!-- Actuators: 4 rotors applying +z force at each site (body frame) -->
  <actuator>
    <general name="rotor1" site="rotor1_site" gear="0 0 1 0 0 0"/>
    <general name="rotor2" site="rotor2_site" gear="0 0 1 0 0 0"/>
    <general name="rotor3" site="rotor3_site" gear="0 0 1 0 0 0"/>
    <general name="rotor4" site="rotor4_site" gear="0 0 1 0 0 0"/>
  </actuator>
</mujoco>
